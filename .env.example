# Backend API Base URL
# For local development with Android Emulator, use http://10.0.2.2:8000
# For local development with iOS Simulator or Web, use http://localhost:8000
# For production, always use HTTPS, e.g., https://api.yourdomain.com
EXPO_PUBLIC_API_URL=http://localhost:8000

# Supabase Configuration (Auth Only — all data queries go through FastAPI)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
