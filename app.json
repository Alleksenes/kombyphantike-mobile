{
  "expo": {
    "name": "kombyphantike",
    "slug": "kombyphantike",
    "version": "1.0.0",
    "newArchEnabled": true,
    "android": {
      "package": "com.alleksenes.kombyphantike",
      "compileSdkVersion": 35,
      "targetSdkVersion": 35,
      "usesCleartextTraffic": true,
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      "expo-router",
      "expo-video",
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "android": {
            "newArchEnabled": true,
            "kotlinVersion": "2.1.20"
          }
        }
      ]
    ]
  }
}