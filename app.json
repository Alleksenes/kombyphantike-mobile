{
  "expo": {
    "name": "kombyphantike",
    "slug": "kombyphantike",
    "version": "1.0.0",
    "newArchEnabled": false,
    "android": {
      "package": "com.alleksenes.kombyphantike",
      "ndkVersion": "26.1.10909125",
      "usesCleartextTraffic": true,
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png",
      "backgroundColor": "#0a0f0d"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1a1918",
          "dark": {
            "backgroundColor": "#1a1918"
          }
        }
      ],
      "expo-video",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}